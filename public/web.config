<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>

    <!-- ─────────────────────────────────────────────
         SPA fallback: rewrite all non-file, non-folder
         requests to index.html so React Router works.
    ───────────────────────────────────────────────── -->
    <rewrite>
      <rules>
        <rule name="SPA Fallback" stopProcessing="true">
          <match url=".*" />
          <conditions logicalGrouping="MatchAll">
            <!-- Not a real file (e.g. main.js, style.css) -->
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
            <!-- Not a real folder -->
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
            <!-- Not the API path (uncomment when you add a backend) -->
            <!-- <add input="{REQUEST_URI}" pattern="^/api/" negate="true" /> -->
          </conditions>
          <action type="Rewrite" url="/index.html" />
        </rule>
      </rules>
    </rewrite>

    <!-- ─────────────────────────────────────────────
         Static file MIME types — Azure IIS doesn't
         always know about .webmanifest or .woff2.
    ───────────────────────────────────────────────── -->
    <staticContent>
      <remove fileExtension=".webmanifest" />
      <mimeMap fileExtension=".webmanifest" mimeType="application/manifest+json" />
      <remove fileExtension=".woff" />
      <mimeMap fileExtension=".woff" mimeType="font/woff" />
      <remove fileExtension=".woff2" />
      <mimeMap fileExtension=".woff2" mimeType="font/woff2" />
    </staticContent>

    <!-- ─────────────────────────────────────────────
         Cache-control headers.
         Vite hashes JS/CSS filenames on every build,
         so those assets can be cached forever.
         index.html must never be cached — it's the
         entry point and changes on every deploy.
    ───────────────────────────────────────────────── -->
    <httpProtocol>
      <customHeaders>
        <!-- Prevent clickjacking -->
        <add name="X-Frame-Options" value="SAMEORIGIN" />
        <!-- Block MIME sniffing -->
        <add name="X-Content-Type-Options" value="nosniff" />
        <!-- Basic XSS protection for older browsers -->
        <add name="X-XSS-Protection" value="1; mode=block" />
        <!-- Force HTTPS (1 year) -->
        <add name="Strict-Transport-Security" value="max-age=31536000; includeSubDomains" />
        <!-- Referrer policy -->
        <add name="Referrer-Policy" value="strict-origin-when-cross-origin" />
      </customHeaders>
    </httpProtocol>

    <!-- ─────────────────────────────────────────────
         Output caching for hashed Vite assets.
         index.html: no-cache (always fresh).
         /assets/*: immutable for 1 year.
    ───────────────────────────────────────────────── -->
    <caching>
      <profiles>
        <add extension=".html" policy="DisableCache" kernelCachePolicy="DisableCache" />
      </profiles>
    </caching>

    <!-- ─────────────────────────────────────────────
         Compression — reduces payload for JS/CSS.
    ───────────────────────────────────────────────── -->
    <urlCompression doStaticCompression="true" doDynamicCompression="true" />

    <!-- ─────────────────────────────────────────────
         Remove the "X-Powered-By: ASP.NET" header.
    ───────────────────────────────────────────────── -->
    <httpProtocol>
      <customHeaders>
        <remove name="X-Powered-By" />
      </customHeaders>
    </httpProtocol>

  </system.webServer>
</configuration>
